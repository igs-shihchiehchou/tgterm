# Copy to .env and fill in. Never commit the real .env.

# From @BotFather when you create your bot.
BOT_TOKEN=123456:ABC-your-bot-token

# Your Telegram numeric user id(s), comma-separated. Only these may use the bot.
# Don't know yours? Start the bot, message it, it replies with your id.
ALLOWED_USER_IDS=11111111

# Seconds before a command is considered "still running" (then use /c).
CMD_TIMEOUT=30

# Vim leader key, as a tmux key name (Space, comma "," , backslash "\\").
VIM_LEADER=Space
